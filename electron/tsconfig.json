{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"],
    "noEmit": true
  },
  "include": ["src/**/*", "../src/**/*"],
  "exclude": ["**/*.test.ts"]
}
